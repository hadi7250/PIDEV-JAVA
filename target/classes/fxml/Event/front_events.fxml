<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.FrontEventsController"
            stylesheets="@../../styles/modern.css"
            prefWidth="1200" prefHeight="760">

    <top>
        <VBox spacing="20" styleClass="front-header">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <!-- Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="🏠 Accueil" onAction="#goHome" styleClass="btn, btn-outline"/>
                <Separator orientation="VERTICAL" prefHeight="20"/>
                <Button text="🎭 Événements" onAction="#showEventsPage" styleClass="btn, btn-outline"/>
                <Button text="📝 Mes avis" onAction="#showMyReviewsPage" styleClass="btn, btn-outline"/>
                <Button text="🏆 Mes certificats" onAction="#showMyCertificatesPage" styleClass="btn, btn-outline"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="titleLabel" text="EduConnect" styleClass="front-title"/>
            </HBox>

            <!-- Search Bar (Independent & Lower) -->
            <HBox alignment="CENTER" spacing="12" style="-fx-padding: 10 0 0 0;">
                <TextField fx:id="searchField" promptText="🔍 Rechercher un événement (tapez pour chercher)..." prefWidth="550" styleClass="search-field" onAction="#onSearch"/>
                <Button text="🎤 Vocal" onAction="#onVoiceSearch" styleClass="btn, btn-outline"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="frontContentStack">
            <ScrollPane fx:id="eventsPageScroll" fitToWidth="true" styleClass="front-scroll">
                <FlowPane fx:id="eventsContainer" hgap="20" vgap="20" alignment="CENTER" styleClass="events-flow">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                </FlowPane>
            </ScrollPane>

            <ScrollPane fx:id="eventDetailsScroll" fitToWidth="true" styleClass="front-scroll" visible="false" managed="false">
                <VBox fx:id="eventDetailsContainer" spacing="12">
                    <padding>
                        <Insets top="22" right="26" bottom="22" left="26"/>
                    </padding>
                </VBox>
            </ScrollPane>

            <ScrollPane fx:id="myReviewsScroll" fitToWidth="true" styleClass="front-scroll" visible="false" managed="false">
                <VBox fx:id="myReviewsContainer" spacing="10">
                    <padding>
                        <Insets top="22" right="26" bottom="22" left="26"/>
                    </padding>
                </VBox>
            </ScrollPane>

            <ScrollPane fx:id="myCertificatesScroll" fitToWidth="true" styleClass="front-scroll" visible="false" managed="false">
                <VBox fx:id="myCertificatesContainer" spacing="10">
                    <padding>
                        <Insets top="22" right="26" bottom="22" left="26"/>
                    </padding>
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>
</BorderPane>
