<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="mainContainer" spacing="15" styleClass="light-theme" stylesheets="@../css/courses-module.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AfficherPersonne">
    <padding>
        <Insets bottom="25" left="25" right="25" top="25"/>
    </padding>

    <!-- Header with Title, Logout, and Theme Toggle -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="title-label" text="📋 User Management" />
            <Label fx:id="adminInfoLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #666;" />
        </VBox>
        <Button onAction="#logout" text="🚪 Logout" styleClass="btn-danger" />
        <Button onAction="#toggleTheme" text="🌙 Dark Mode" styleClass="theme-toggle-btn" />
    </HBox>

    <!-- Search Section -->
    <VBox spacing="10">
        <Label styleClass="subtitle-label" text="🔍 Search Users" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Type a name or first name..." styleClass="search-field" HBox.hgrow="ALWAYS" />
            <Button onAction="#searchUsers" text="Search" styleClass="btn-info" />
            <Button onAction="#resetSearch" text="Reset" styleClass="btn-primary" />
        </HBox>
    </VBox>

    <!-- Table Section -->
    <VBox spacing="10">
        <Label styleClass="subtitle-label" text="📊 User List" />
        <TableView fx:id="tableView" prefHeight="300">
            <columns>
                <TableColumn fx:id="idCol" prefWidth="50" text="ID"/>
                <TableColumn fx:id="nomCol" prefWidth="150" text="Last Name"/>
                <TableColumn fx:id="prenomCol" prefWidth="150" text="First Name"/>
                <TableColumn fx:id="ageCol" prefWidth="80" text="Age"/>
                <TableColumn fx:id="emailCol" prefWidth="200" text="Email"/>
                <TableColumn fx:id="roleCol" prefWidth="100" text="Role"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Edit Section -->
    <VBox spacing="10" styleClass="input-card">
        <Label styleClass="subtitle-label" text="✏️ Edit User" />
        <Label text="Select a user from the table to edit" style="-fx-font-size: 11px;" />

        <HBox spacing="15">
            <TextField fx:id="editNomField" promptText="Last Name" prefWidth="140" />
            <TextField fx:id="editPrenomField" promptText="First Name" prefWidth="140" />
            <TextField fx:id="editAgeField" promptText="Age" prefWidth="80" />
            <TextField fx:id="editEmailField" promptText="Email" prefWidth="180" />
            <ComboBox fx:id="editRoleCombo" promptText="Role" prefWidth="100" />
        </HBox>

        <HBox spacing="15">
            <PasswordField fx:id="editPasswordField" promptText="New password (optional)" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button onAction="#updateUser" text="✏️ Update" styleClass="btn-warning" />
        <Button onAction="#deleteUser" text="🗑️ Delete" styleClass="btn-danger" />
        <Button onAction="#refreshTable" text="🔄 Refresh" styleClass="btn-info" />
        <Button onAction="#goToAddUser" text="➕ Add User" styleClass="btn-primary" />
    </HBox>
</VBox>
