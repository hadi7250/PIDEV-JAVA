<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ForumController"
      styleClass="forum-container"
      spacing="15">

    <!-- Header with search, filters, and notifications -->
    <VBox styleClass="forum-header" spacing="10">
        <padding>
            <Insets top="15" right="20" left="20" bottom="10"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Forum Discussions" styleClass="forum-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="notificationBtn" text="🔔" styleClass="notification-btn" onAction="#showNotifications"/>
                <Label fx:id="notificationBadge" text="0" styleClass="notification-badge" visible="false"/>
            </HBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15">
            <TextField fx:id="searchField" promptText="Search discussions..." prefWidth="300" styleClass="search-field"/>
            <ComboBox fx:id="categoryFilter" promptText="All Categories" prefWidth="200" styleClass="category-filter"/>
            <Button text="➕ New Discussion" styleClass="primary-btn" onAction="#showCreateDiscussionDialog"/>
        </HBox>

        <Separator styleClass="forum-separator"/>
    </VBox>

    <!-- Main content area -->
    <HBox VBox.vgrow="ALWAYS" spacing="15">
        <padding>
            <Insets right="20" left="20"/>
        </padding>

        <!-- Discussion list -->
        <VBox HBox.hgrow="ALWAYS" prefWidth="300" spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Discussions" styleClass="section-title"/>
                <Label fx:id="totalLabel" text="0 discussions" styleClass="section-count"/>
            </HBox>

            <ScrollPane fx:id="discussionScrollPane" fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <VBox fx:id="discussionCardsBox" spacing="10" styleClass="discussion-list">
                    <padding>
                        <Insets top="5" right="5" left="5" bottom="5"/>
                    </padding>
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- Discussion details -->
        <VBox HBox.hgrow="ALWAYS" prefWidth="500" spacing="10" styleClass="discussion-details">
            <Label text="Discussion Details" styleClass="section-title"/>

            <VBox fx:id="discussionDetailBox" spacing="10" styleClass="detail-content">
                <padding>
                    <Insets top="10" right="15" left="15" bottom="15"/>
                </padding>

                <!-- Discussion header -->
                <VBox fx:id="discussionHeaderBox" spacing="8">
                    <Label fx:id="selectedTitle" text="Select a discussion" styleClass="discussion-title"/>
                    <Label fx:id="selectedMeta" text="Open a discussion card to see replies" styleClass="discussion-meta"/>
                    <Label fx:id="lockedNotice" text="" styleClass="locked-notice" visible="false" managed="false"/>
                </VBox>

                <Separator/>

                <!-- Discussion content -->
                <TextArea fx:id="selectedContent" text="" styleClass="discussion-content" wrapText="true" editable="false" prefRowCount="4"/>

                <Separator/>

                <!-- Messages section -->
                <VBox spacing="10">
                    <Label text="Replies" styleClass="replies-title"/>
                    <ScrollPane fx:id="messagesScroll" fitToWidth="true" hbarPolicy="NEVER" prefHeight="300" VBox.vgrow="ALWAYS">
                        <VBox fx:id="messagesBox" spacing="8" styleClass="messages-list">
                            <padding>
                                <Insets top="5" right="5" left="5" bottom="5"/>
                            </padding>
                        </VBox>
                    </ScrollPane>
                </VBox>

                <!-- Reply section -->
                <VBox fx:id="replySection" spacing="8" styleClass="reply-section">
                    <Separator/>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Post Reply" styleClass="reply-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="markSolvedBtn" text="✅ Mark as Solved" styleClass="solved-btn" visible="false" managed="false"/>
                    </HBox>

                    <VBox spacing="5">
                        <TextField fx:id="replyAuthorField" promptText="Your name" editable="false" styleClass="reply-author"/>
                        <TextArea fx:id="replyContentArea" promptText="Write your reply here..." prefRowCount="4" wrapText="true" styleClass="reply-content"/>
                        <Label fx:id="replyContentErrorLabel" text="" styleClass="error-label" visible="false" managed="false"/>
                        <Label fx:id="badWordWarningLabel" text="" styleClass="warning-label" visible="false" managed="false"/>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="postReplyBtn" text="Post Reply" styleClass="primary-btn" onAction="#postReply"/>
                    </HBox>
                </VBox>

                <!-- Empty state -->
                <VBox fx:id="emptyStateBox" alignment="CENTER" spacing="10" visible="false" managed="false">
                    <Label fx:id="emptyStateLabel" text="No discussion selected" styleClass="empty-state-label"/>
                </VBox>
            </VBox>
        </VBox>
    </HBox>

</VBox>
