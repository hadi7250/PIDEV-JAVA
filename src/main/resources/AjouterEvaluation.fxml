<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?><?import javafx.scene.layout.*?><?import java.net.URL?>

<VBox fx:id="mainContainer" spacing="20" styleClass="light-theme" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterEvaluationController" prefWidth="600" prefHeight="600" >
    <padding>
        <Insets bottom="30" left="30" right="30" top="30"/>
    </padding>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label styleClass="title-label" text="➕ Create New Evaluation" HBox.hgrow="ALWAYS" />
        <Button onAction="#toggleTheme" text="🌙 Dark Mode" styleClass="theme-toggle-btn" />
    </HBox>

    <VBox spacing="15" styleClass="input-card" VBox.vgrow="ALWAYS">
        <Label styleClass="subtitle-label" text="Evaluation Information" />

        <VBox spacing="5">
            <Label text="Title" styleClass="label-bold" />
            <TextField fx:id="titleField" promptText="Enter title" />
        </VBox>

        <VBox spacing="5">
            <Label text="Description" styleClass="label-bold" />
            <TextArea fx:id="descriptionArea" promptText="Enter description" prefHeight="80" />
        </VBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Type" styleClass="label-bold" />
                <ComboBox fx:id="typeComboBox" maxWidth="Infinity" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Date" styleClass="label-bold" />
                <DatePicker fx:id="datePicker" maxWidth="Infinity" />
            </VBox>
        </HBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Weight (0-100)" styleClass="label-bold" />
                <TextField fx:id="weightField" promptText="Enter weight" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Competence" styleClass="label-bold" />
                <ComboBox fx:id="competenceComboBox" maxWidth="Infinity" />
            </VBox>
        </HBox>
    </VBox>

    <HBox spacing="20" alignment="CENTER">
        <Button onAction="#handleCreate" text="✅ Create Evaluation" styleClass="btn-primary" />
        <Button onAction="#handleCancel" text="✖ Cancel" styleClass="btn-secondary" />
    </HBox>
</VBox>