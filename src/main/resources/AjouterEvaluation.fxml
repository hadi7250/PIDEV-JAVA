<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?><?import javafx.scene.layout.*?><?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterEvaluationController" prefWidth="600" prefHeight="500" styleClass="main-container" stylesheets="@style.css" >
    <children>
        <Label text="Create New Evaluation" style="-fx-font-size: 24; -fx-font-weight: bold;" />
        <GridPane hgap="10" vgap="15" alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints prefWidth="150" />
                <ColumnConstraints prefWidth="250" />
            </columnConstraints>
            <children>
                <Label text="Title:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="titleField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                
                <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextArea fx:id="descriptionArea" prefHeight="80" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                
                <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="typeComboBox" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                
                <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <DatePicker fx:id="datePicker" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                
                <Label text="Weight (0-100):" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="weightField" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                
                <Label text="Competence:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <ComboBox fx:id="competenceComboBox" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </children>
        </GridPane>
        <HBox spacing="10" alignment="CENTER">
            <Button text="Create Evaluation" fx:id="createButton" onAction="#handleCreate" />
            <Button text="Cancel" fx:id="cancelButton" onAction="#handleCancel" />
        </HBox>
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>