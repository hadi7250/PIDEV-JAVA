<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="700.0" prefWidth="850.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterEvaluationController">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="module-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title" text="Create New Evaluation" />
                    <Label styleClass="module-subtitle" text="Set up a new assessment, exam, or project for your students." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#toggleTheme" styleClass="secondary-btn" text="🌓 Theme" />
            </HBox>
        </top>

        <center>
            <VBox alignment="CENTER" style="-fx-padding: 30 0 0 0;">
                <VBox maxWidth="650.0" spacing="20.0" styleClass="module-card">
                    <Label styleClass="section-title" text="📝 Evaluation Assignment" />
                    
                    <VBox spacing="15.0">
                        <VBox spacing="5">
                            <Label styleClass="label-bold" text="Evaluation Title" />
                            <TextField fx:id="titleField" promptText="e.g. Midterm Java Exam" />
                        </VBox>
                        
                        <VBox spacing="5">
                            <Label styleClass="label-bold" text="Instructions/Description" />
                            <TextArea fx:id="descriptionArea" prefHeight="100" promptText="Enter evaluation instructions or topics covered..." wrapText="true" />
                        </VBox>

                        <HBox spacing="15">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label styleClass="label-bold" text="Assessment Type" />
                                <ComboBox fx:id="typeComboBox" maxWidth="Infinity" promptText="Select type" />
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label styleClass="label-bold" text="Due Date" />
                                <DatePicker fx:id="datePicker" maxWidth="Infinity" promptText="Select date" />
                            </VBox>
                        </HBox>

                        <HBox spacing="15">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label styleClass="label-bold" text="Weight/Score Max (0-100)" />
                                <TextField fx:id="weightField" promptText="e.g. 20.0" />
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label styleClass="label-bold" text="Target Competence" />
                                <ComboBox fx:id="competenceComboBox" maxWidth="Infinity" promptText="Link to a skill" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <Separator />

                    <HBox alignment="CENTER" spacing="20">
                        <Button onAction="#handleCancel" prefWidth="150.0" styleClass="secondary-btn" text="✖ Cancel" />
                        <Button onAction="#handleCreate" prefWidth="200.0" styleClass="primary-btn" text="🚀 Publish Evaluation" />
                    </HBox>
                </VBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
