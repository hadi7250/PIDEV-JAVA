<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="750.0" prefWidth="1100.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AfficherCompetencesController">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="module-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title" text="My Competences" />
                    <Label styleClass="module-subtitle" text="Manage your skills and professional certifications." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#goBack" styleClass="secondary-btn" text="← Back" />
                <Button onAction="#goToProfile" styleClass="info-btn" text="👤 Profile" />
                <Button onAction="#goToEvaluations" styleClass="primary-btn" text="📋 View My Evaluations" />
                <Button onAction="#toggleTheme" styleClass="secondary-btn" text="🌓 Theme" />
            </HBox>
        </top>

        <center>
            <SplitPane dividerPositions="0.65" style="-fx-padding: 20 0 0 0;">
                <items>
                    <!-- Left Side: Table -->
                    <VBox spacing="15.0" styleClass="module-card">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="section-title" text="Competence List" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="searchField" prefWidth="250.0" promptText="Search competences..." styleClass="search-field" />
                        </HBox>
                        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="nameCol" prefWidth="150" text="Name" />
                                <TableColumn fx:id="categoryCol" prefWidth="120" text="Category" />
                                <TableColumn fx:id="levelCol" prefWidth="80" text="Level" />
                                <TableColumn fx:id="descCol" prefWidth="250" text="Description" />
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Right Side: Edit Form -->
                    <VBox spacing="15.0" styleClass="module-card">
                        <Label styleClass="section-title" text="Edit Competence" />
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                            <VBox spacing="15.0">
                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Name" />
                                    <TextField fx:id="editNameField" promptText="Enter competence name" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Description" />
                                    <TextArea fx:id="editDescriptionArea" prefHeight="100" promptText="Describe this skill" wrapText="true" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Category" />
                                    <ComboBox fx:id="editCategoryCombo" maxWidth="Infinity" promptText="Select category" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Level (1-10)" />
                                    <Slider fx:id="editLevelSlider" max="10" min="1" showTickLabels="true" />
                                </VBox>
                                
                                <Separator />
                                
                                <VBox spacing="10.0" alignment="CENTER">
                                    <Button maxWidth="Infinity" onAction="#handleUpdate" styleClass="primary-btn" text="💾 Update Changes" />
                                    <Button maxWidth="Infinity" onAction="#handleDelete" styleClass="danger-btn" text="🗑️ Delete Competence" />
                                    <Button maxWidth="Infinity" onAction="#goToAdd" styleClass="info-btn" text="➕ Add New Competence" />
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </VBox>
                </items>
            </SplitPane>
        </center>
    </BorderPane>
</StackPane>
