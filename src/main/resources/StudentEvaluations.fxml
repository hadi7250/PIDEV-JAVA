<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="750.0" prefWidth="1100.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.StudentEvaluationsController">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="module-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title" text="My Performance & Evaluations" />
                    <Label styleClass="module-subtitle" text="View your grades, feedback, and academic progress." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#goBack" styleClass="secondary-btn" text="← Back" />
                <Button onAction="#goToProfile" styleClass="info-btn" text="👤 Profile" />
                <Button onAction="#toggleTheme" styleClass="secondary-btn" text="🌓 Theme" />
            </HBox>
        </top>

        <center>
            <VBox spacing="20.0" styleClass="module-card" style="-fx-padding: 25;">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label styleClass="section-title" text="Evaluation History" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="searchField" prefWidth="300.0" promptText="Search by title or competence..." styleClass="search-field" />
                    <ComboBox fx:id="statusFilter" prefWidth="150.0" promptText="Filter by status" />
                </HBox>
                
                <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="compCol" prefWidth="200" text="Competence" />
                        <TableColumn fx:id="titleCol" prefWidth="200" text="Evaluation Title" />
                        <TableColumn fx:id="scoreCol" prefWidth="100" text="My Score" />
                        <TableColumn fx:id="dateCol" prefWidth="150" text="Date" />
                        <TableColumn fx:id="statusCol" prefWidth="120" text="Status" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <Button onAction="#handleExport" styleClass="info-btn" text="📥 Export Report (CSV)" />
                </HBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
