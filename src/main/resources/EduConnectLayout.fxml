<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane fx:id="shellRoot" prefHeight="760.0" prefWidth="1280.0" styleClass="shell-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.EduConnectController">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="shell-topbar">
            <padding>
                <Insets bottom="18.0" left="24.0" right="24.0" top="18.0" />
            </padding>
            <VBox spacing="4.0">
                <Label styleClass="hero-title" text="EduConnect" />
                <Label fx:id="roleLabel" styleClass="hero-subtitle" text="Professional Competence &amp; Evaluation Management" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle-btn" text="Dark mode" />
            <Button onAction="#handleLogout" styleClass="danger-btn" text="🚪 Logout" />
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebar" spacing="10.0" styleClass="shell-sidebar">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            
            <VBox fx:id="adminMenu" spacing="10.0">
                <Label styleClass="section-title" text="Administration" />
                <Button maxWidth="Infinity" onAction="#openUserManagement" styleClass="nav-btn" text="👥 User Management" />
            </VBox>

            <VBox fx:id="teacherMenu" spacing="10.0">
                <Label styleClass="section-title" text="Teaching" />
                <Button maxWidth="Infinity" onAction="#openEvaluationManagement" styleClass="nav-btn" text="📝 Evaluations" />
            </VBox>

            <VBox fx:id="studentMenu" spacing="10.0">
                <Label styleClass="section-title" text="Learning" />
                <Button maxWidth="Infinity" onAction="#openCompetences" styleClass="nav-btn" text="🎯 My Competences" />
                <Button maxWidth="Infinity" onAction="#openMyEvaluations" styleClass="nav-btn" text="📊 My Grades" />
            </VBox>

            <Separator />
            
            <Label styleClass="section-title" text="Account" />
            <Button maxWidth="Infinity" onAction="#openProfile" styleClass="nav-btn" text="👤 My Profile" />

            <Region VBox.vgrow="ALWAYS" />
            
            <Label fx:id="userWelcomeLabel" styleClass="meta-label" text="Welcome, User" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentHost" styleClass="shell-content">
            <!-- Modules will be loaded here -->
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </StackPane>
    </center>
</BorderPane>
