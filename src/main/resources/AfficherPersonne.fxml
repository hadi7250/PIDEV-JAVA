<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="mainContainer" spacing="15" styleClass="light-theme" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AfficherPersonne">
    <padding>
        <Insets bottom="25" left="25" right="25" top="25"/>
    </padding>

    <!-- Header with Title and Theme Toggle -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label styleClass="title-label" text="📋 Gestion des Personnes" HBox.hgrow="ALWAYS" />
        <Button onAction="#toggleTheme" text="🌙 Dark Mode" styleClass="theme-toggle-btn" />
    </HBox>

    <!-- Search Section -->
    <VBox spacing="10">
        <Label styleClass="subtitle-label" text="🔍 Rechercher une personne" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Tapez un nom ou prénom..." styleClass="search-field" HBox.hgrow="ALWAYS" />
            <Button onAction="#searchPersons" text="Rechercher" styleClass="btn-info" />
            <Button onAction="#resetSearch" text="Réinitialiser" styleClass="btn-primary" />
        </HBox>
    </VBox>

    <!-- Table Section -->
    <VBox spacing="10">
        <Label styleClass="subtitle-label" text="📊 Liste des personnes" />
        <TableView fx:id="tableView" prefHeight="300">
            <columns>
                <TableColumn fx:id="nomCol" prefWidth="180" text="Nom"/>
                <TableColumn fx:id="prenomCol" prefWidth="180" text="Prénom"/>
                <TableColumn fx:id="ageCol" prefWidth="100" text="Âge"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Edit Section -->
    <VBox spacing="10" styleClass="input-card">
        <Label styleClass="subtitle-label" text="✏️ Modifier une personne" />
        <Label text="Sélectionnez une personne dans le tableau pour la modifier" style="-fx-font-size: 11px;" />
        <HBox spacing="15">
            <TextField fx:id="editNomField" promptText="Nom" prefWidth="160" />
            <TextField fx:id="editPrenomField" promptText="Prénom" prefWidth="160" />
            <TextField fx:id="editAgeField" promptText="Âge" prefWidth="100" />
        </HBox>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button onAction="#updatePerson" text="✏️ Modifier" styleClass="btn-warning" />
        <Button onAction="#deletePerson" text="🗑️ Supprimer" styleClass="btn-danger" />
        <Button onAction="#refreshTable" text="🔄 Actualiser" styleClass="btn-info" />
        <Button onAction="#goBackToAdd" text="➕ Ajouter une personne" styleClass="btn-primary" />
    </HBox>
</VBox>