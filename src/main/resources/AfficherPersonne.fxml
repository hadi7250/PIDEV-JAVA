<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="mainContainer" spacing="15" styleClass="light-theme" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AfficherPersonne">
    <padding>
        <Insets bottom="25" left="25" right="25" top="25"/>
    </padding>

    <!-- Header with Title, Logout, and Theme Toggle -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="title-label" text="📋 Gestion des Utilisateurs" />
            <Label fx:id="adminInfoLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #666;" />
        </VBox>
        <Button onAction="#logout" text="🚪 Logout" styleClass="btn-danger" />
        <Button onAction="#toggleTheme" text="🌙 Dark Mode" styleClass="theme-toggle-btn" />
    </HBox>

    <!-- Search Section -->
    <VBox spacing="10">
        <Label styleClass="subtitle-label" text="🔍 Rechercher un utilisateur" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Tapez un nom ou prénom..." styleClass="search-field" HBox.hgrow="ALWAYS" />
            <Button onAction="#searchUsers" text="Rechercher" styleClass="btn-info" />
            <Button onAction="#resetSearch" text="Réinitialiser" styleClass="btn-primary" />
        </HBox>
    </VBox>

    <!-- Table Section -->
    <VBox spacing="10">
        <Label styleClass="subtitle-label" text="📊 Liste des utilisateurs" />
        <TableView fx:id="tableView" prefHeight="300">
            <columns>
                <TableColumn fx:id="idCol" prefWidth="50" text="ID"/>
                <TableColumn fx:id="nomCol" prefWidth="150" text="Nom"/>
                <TableColumn fx:id="prenomCol" prefWidth="150" text="Prénom"/>
                <TableColumn fx:id="ageCol" prefWidth="80" text="Âge"/>
                <TableColumn fx:id="emailCol" prefWidth="200" text="Email"/>
                <TableColumn fx:id="roleCol" prefWidth="100" text="Rôle"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Edit Section -->
    <VBox spacing="10" styleClass="input-card">
        <Label styleClass="subtitle-label" text="✏️ Modifier un utilisateur" />
        <Label text="Sélectionnez un utilisateur dans le tableau pour le modifier" style="-fx-font-size: 11px;" />

        <HBox spacing="15">
            <TextField fx:id="editNomField" promptText="Nom" prefWidth="140" />
            <TextField fx:id="editPrenomField" promptText="Prénom" prefWidth="140" />
            <TextField fx:id="editAgeField" promptText="Âge" prefWidth="80" />
            <TextField fx:id="editEmailField" promptText="Email" prefWidth="180" />
            <ComboBox fx:id="editRoleCombo" promptText="Rôle" prefWidth="100" />
        </HBox>

        <HBox spacing="15">
            <PasswordField fx:id="editPasswordField" promptText="Nouveau mot de passe (optionnel)" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button onAction="#updateUser" text="✏️ Modifier" styleClass="btn-warning" />
        <Button onAction="#deleteUser" text="🗑️ Supprimer" styleClass="btn-danger" />
        <Button onAction="#refreshTable" text="🔄 Actualiser" styleClass="btn-info" />
        <Button onAction="#goToAddUser" text="➕ Ajouter un utilisateur" styleClass="btn-primary" />
    </HBox>
</VBox>