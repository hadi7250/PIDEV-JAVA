<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="750.0" prefWidth="1200.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AfficherPersonne">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="module-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title" text="Admin Dashboard - User Management" />
                    <Label fx:id="adminInfoLabel" styleClass="module-subtitle" text="👑 Logged in as: Admin" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#refreshTable" styleClass="secondary-btn" text="🔄 Refresh" />
                <Button onAction="#toggleTheme" styleClass="secondary-btn" text="🌓 Theme" />
                <Button onAction="#logout" styleClass="danger-btn" text="🚪 Logout" />
            </HBox>
        </top>

        <center>
            <SplitPane dividerPositions="0.65" style="-fx-padding: 20 0 0 0;">
                <items>
                    <!-- Left Side: Table -->
                    <VBox spacing="15.0" styleClass="module-card">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="section-title" text="Registered Users" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="searchField" prefWidth="300.0" promptText="Search by name or email..." styleClass="search-field" />
                            <Button onAction="#resetSearch" styleClass="secondary-btn" text="Reset" />
                        </HBox>
                        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" prefWidth="50" text="ID" />
                                <TableColumn fx:id="prenomCol" prefWidth="120" text="First Name" />
                                <TableColumn fx:id="nomCol" prefWidth="120" text="Last Name" />
                                <TableColumn fx:id="ageCol" prefWidth="60" text="Age" />
                                <TableColumn fx:id="emailCol" prefWidth="200" text="Email" />
                                <TableColumn fx:id="roleCol" prefWidth="100" text="Role" />
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Right Side: Edit Form -->
                    <VBox spacing="15.0" styleClass="module-card">
                        <Label styleClass="section-title" text="Manage User" />
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                            <VBox spacing="15.0">
                                <HBox spacing="10">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="label-bold" text="First Name" />
                                        <TextField fx:id="editPrenomField" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="label-bold" text="Last Name" />
                                        <TextField fx:id="editNomField" />
                                    </VBox>
                                </HBox>
                                
                                <HBox spacing="10">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="label-bold" text="Age" />
                                        <TextField fx:id="editAgeField" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="label-bold" text="Role" />
                                        <ComboBox fx:id="editRoleCombo" maxWidth="Infinity" />
                                    </VBox>
                                </HBox>

                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Email" />
                                    <TextField fx:id="editEmailField" />
                                </VBox>

                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Reset Password" />
                                    <PasswordField fx:id="editPasswordField" promptText="Leave empty to keep current" />
                                </VBox>
                                
                                <Separator />
                                
                                <VBox spacing="10.0" alignment="CENTER">
                                    <Button maxWidth="Infinity" onAction="#updateUser" styleClass="primary-btn" text="💾 Update User Info" />
                                    <Button maxWidth="Infinity" onAction="#deleteUser" styleClass="danger-btn" text="🗑️ Delete Account" />
                                    <Separator />
                                    <Button maxWidth="Infinity" onAction="#goToAddUser" styleClass="info-btn" text="➕ Create New User" />
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </VBox>
                </items>
            </SplitPane>
        </center>
    </BorderPane>
</StackPane>
