<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane prefHeight="750.0" prefWidth="900.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.SignUpController">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <VBox alignment="CENTER" spacing="20.0">
        <VBox maxWidth="550.0" spacing="20.0" styleClass="module-card" style="-fx-padding: 35;">
            <VBox alignment="CENTER" spacing="5.0">
                <Label styleClass="hero-title" text="Join EduConnect" style="-fx-text-fill: #1a7d73; -fx-font-size: 28px;" />
                <Label styleClass="module-subtitle" text="Create your account to start managing your journey." />
            </VBox>
            
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>
                
                <children>
                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label styleClass="label-bold" text="First Name" />
                        <TextField fx:id="firstNameField" promptText="First name" />
                    </VBox>
                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label styleClass="label-bold" text="Last Name" />
                        <TextField fx:id="lastNameField" promptText="Last name" />
                    </VBox>
                    
                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label styleClass="label-bold" text="Age" />
                        <TextField fx:id="ageField" promptText="Your age" />
                    </VBox>
                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label styleClass="label-bold" text="Desired Role" />
                        <ComboBox fx:id="roleComboBox" maxWidth="Infinity" />
                    </VBox>
                    
                    <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                        <Label styleClass="label-bold" text="Email Address" />
                        <TextField fx:id="emailField" promptText="example@domain.com" />
                    </VBox>
                    
                    <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label styleClass="label-bold" text="Password" />
                        <PasswordField fx:id="passwordField" promptText="Strong password" />
                    </VBox>
                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <Label styleClass="label-bold" text="Confirm Password" />
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" />
                    </VBox>
                </children>
            </GridPane>

            <Button maxWidth="Infinity" onAction="#handleSignUp" styleClass="primary-btn" text="✅ Create Account" style="-fx-pref-height: 45; -fx-font-size: 15px;" />
            
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="Already have an account?" styleClass="meta-label" />
                <Button onAction="#goToSignIn" styleClass="secondary-btn" text="Sign In Instead" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>
