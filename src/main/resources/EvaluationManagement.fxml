<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="750.0" prefWidth="1100.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.EvaluationManagementController">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="module-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title" text="Evaluation Management" />
                    <Label styleClass="module-subtitle" text="Grade students, provide feedback, and track performance." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#goBack" styleClass="secondary-btn" text="← Back" />
                <Button onAction="#goToProfile" styleClass="info-btn" text="👤 Profile" />
                <Button onAction="#toggleTheme" styleClass="secondary-btn" text="🌓 Theme" />
            </HBox>
        </top>

        <center>
            <SplitPane dividerPositions="0.65" style="-fx-padding: 20 0 0 0;">
                <items>
                    <!-- Left Side: Table -->
                    <VBox spacing="15.0" styleClass="module-card">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="section-title" text="Evaluation Records" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="searchField" prefWidth="250.0" promptText="Search evaluations..." styleClass="search-field" />
                        </HBox>
                        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="compCol" prefWidth="150" text="Competence" />
                                <TableColumn fx:id="titleCol" prefWidth="150" text="Title" />
                                <TableColumn fx:id="scoreCol" prefWidth="80" text="Score" />
                                <TableColumn fx:id="statusCol" prefWidth="100" text="Status" />
                                <TableColumn fx:id="dateCol" prefWidth="120" text="Date" />
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Right Side: Grade Form -->
                    <VBox spacing="15.0" styleClass="module-card">
                        <Label styleClass="section-title" text="Grade & Feedback" />
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                            <VBox spacing="15.0">
                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Score (0-100)" />
                                    <TextField fx:id="scoreField" promptText="Enter numerical score" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Status" />
                                    <ComboBox fx:id="statusCombo" maxWidth="Infinity" promptText="Change status" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label styleClass="label-bold" text="Teacher Comment" />
                                    <TextArea fx:id="commentArea" prefHeight="120" promptText="Provide constructive feedback..." wrapText="true" />
                                </VBox>
                                
                                <Separator />
                                
                                <VBox spacing="10.0" alignment="CENTER">
                                    <Button maxWidth="Infinity" onAction="#handleGrade" styleClass="primary-btn" text="✅ Submit Grade" />
                                    <Button maxWidth="Infinity" onAction="#handleDelete" styleClass="danger-btn" text="🗑️ Delete Record" />
                                    <Button maxWidth="Infinity" onAction="#goToAdd" styleClass="info-btn" text="➕ Create New Evaluation" />
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </VBox>
                </items>
            </SplitPane>
        </center>
    </BorderPane>
</StackPane>
