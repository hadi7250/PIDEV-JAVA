<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane prefHeight="600.0" prefWidth="800.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.SignInController">
    <stylesheets>
        <URL value="@../modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <VBox alignment="CENTER" spacing="30.0">
        <VBox maxWidth="450.0" spacing="25.0" styleClass="module-card" style="-fx-padding: 40;">
            <VBox alignment="CENTER" spacing="10.0">
                <Label styleClass="hero-title" text="EduConnect" style="-fx-text-fill: #1a7d73; -fx-font-size: 32px;" />
                <Label styleClass="module-subtitle" text="Welcome back! Please login to your account." />
            </VBox>
            
            <VBox spacing="15.0">
                <VBox spacing="8.0">
                    <Label styleClass="label-bold" text="Email Address" />
                    <TextField fx:id="emailField" promptText="Enter your email" style="-fx-pref-height: 45;" />
                </VBox>
                
                <VBox spacing="8.0">
                    <Label styleClass="label-bold" text="Password" />
                    <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-pref-height: 45;" />
                </VBox>
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="primary-btn" text="🚀 Login to Dashboard" style="-fx-pref-height: 50; -fx-font-size: 16px;" />
            
            <Separator />
            
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="Don't have an account?" styleClass="meta-label" />
                <Button onAction="#goToSignUp" styleClass="secondary-btn" text="Create Account" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>
