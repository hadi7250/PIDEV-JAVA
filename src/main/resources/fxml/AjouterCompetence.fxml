<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="750.0" prefWidth="1100.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterCompetenceController">
    <stylesheets>
        <URL value="@../modern.css" />
    </stylesheets>

    <BorderPane styleClass="client-dashboard-shell">
        <padding>
            <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
        </padding>

        <top>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="module-toolbar client-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title client-page-title" text="Creation Studio" />
                    <Label styleClass="module-subtitle" text="Register a new skill or professional certification to your portfolio." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleCancel" styleClass="secondary-btn" text="← Back to List" />
            </HBox>
        </top>

        <center>
            <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 40 0 0 0;">
                <VBox maxWidth="700.0" spacing="25.0" styleClass="module-card">
                    <Label styleClass="section-title" text="New Competence Blueprint" />
                    
                    <VBox spacing="20.0">
                        <VBox spacing="8" styleClass="module-card">
                            <Label styleClass="label-bold" text="Skill Identity" />
                            <TextField fx:id="nameField" promptText="e.g. Full-stack Java Development" />
                        </VBox>
                        
                        <VBox spacing="8" styleClass="module-card">
                            <Label styleClass="label-bold" text="Professional Description" />
                            <TextArea fx:id="descriptionArea" prefHeight="120" promptText="Describe the depth and breadth of this competency..." wrapText="true" />
                        </VBox>

                        <HBox spacing="20">
                            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="module-card">
                                <Label styleClass="label-bold" text="Taxonomy Category" />
                                <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" promptText="Choose category" />
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="module-card">
                                <Label styleClass="label-bold" text="Target Proficiency (1-10)" />
                                <Slider fx:id="levelSlider" max="10" min="1" showTickLabels="true" value="5" />
                            </VBox>
                        </HBox>

                        <VBox spacing="8" styleClass="module-card">
                            <Label styleClass="label-bold" text="Supporting Evidence (PDF)" />
                            <HBox alignment="CENTER_LEFT" spacing="20">
                                <Button onAction="#handleUpload" styleClass="info-btn" text="📂 Upload Certificate" />
                                <Label fx:id="fileNameLabel" styleClass="meta-label" text="No evidence attached" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <Separator />

                    <HBox alignment="CENTER" spacing="25">
                        <Button onAction="#handleCancel" prefWidth="180.0" styleClass="secondary-btn" text="Discard" />
                        <Button onAction="#handleAdd" prefWidth="180.0" styleClass="primary-btn" text="Create Competence" />
                    </HBox>
                </VBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
