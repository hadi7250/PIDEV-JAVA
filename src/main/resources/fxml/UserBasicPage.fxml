<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>


<VBox fx:id="mainContainer" spacing="15" styleClass="light-theme" stylesheets="@../css/courses-module.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.UserBasicPageController">
    <padding>
        <Insets bottom="25" left="25" right="25" top="25"/>
    </padding>

    <!-- Header with Welcome, Logout, and Theme Toggle -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="title-label" text="👤 My Profile" />
            <Label fx:id="welcomeLabel" text="" style="-fx-font-size: 14px; -fx-text-fill: #888; -fx-padding: 0 0 0 5;" />
        </VBox>
        <Button onAction="#logout" text="🚪 Logout" styleClass="btn-danger" />
        <Button onAction="#toggleTheme" text="🌙 Dark Mode" styleClass="theme-toggle-btn" />
    </HBox>

    <!-- Profile Card -->
    <VBox spacing="15" styleClass="input-card">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label styleClass="subtitle-label" text="📋 My Information" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="roleBadge" styleClass="role-badge" />
        </HBox>

        <Separator />

        <!-- Profile Picture Section -->
        <HBox spacing="20" alignment="CENTER">
            <VBox alignment="CENTER" spacing="10">
                <Circle fx:id="profileCircle" radius="50" fill="#667eea" stroke="#ddd" strokeWidth="2" />
                <Button onAction="#uploadPhoto" text="📷 Change Photo" styleClass="btn-info" />
            </VBox>
        </HBox>

        <Separator />

        <!-- Information Grid -->
        <GridPane hgap="15" vgap="12">
            <padding>
                <Insets top="5" bottom="5"/>
            </padding>

            <!-- Row 1: First Name -->
            <Label text="First Name:" styleClass="label-bold" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="firstNameField" promptText="First Name" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Last Name:" styleClass="label-bold" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="lastNameField" promptText="Last Name" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <!-- Row 2: Age and Email -->
            <Label text="Age:" styleClass="label-bold" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="ageField" promptText="Age" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Email:" styleClass="label-bold" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="emailField" promptText="Email" GridPane.columnIndex="3" GridPane.rowIndex="1" />

            <!-- Row 3: Role (Read Only) -->
            <Label text="Role:" styleClass="label-bold" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="roleField" editable="false" promptText="Role" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </GridPane>

        <Separator />

        <!-- Change Password Section -->
        <VBox spacing="10">
            <Label text="🔒 Change Password" styleClass="subtitle-label" />

            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="New Password" style="-fx-font-size: 12px;" />
                    <PasswordField fx:id="newPasswordField" promptText="New Password" styleClass="password-field" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Confirm Password" style="-fx-font-size: 12px;" />
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" styleClass="password-field" />
                </VBox>
            </HBox>
            <Label text="Leave blank to keep current password" style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-padding: 0 0 0 5;" />
        </VBox>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button onAction="#updateProfile" text="💾 Save Changes" styleClass="btn-primary" />
        <Button onAction="#refreshProfile" text="🔄 Refresh" styleClass="btn-info" />
    </HBox>

    <!-- Stats Section (Optional) -->
    <HBox spacing="15" alignment="CENTER">
        <VBox spacing="5" styleClass="stat-card">
            <Label text="📅" style="-fx-font-size: 24px;" />
            <Label text="Member Since" style="-fx-font-size: 11px; -fx-text-fill: #888;" />
            <Label fx:id="memberSinceLabel" text="2026" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
        </VBox>
        <VBox spacing="5" styleClass="stat-card">
            <Label text="🆔" style="-fx-font-size: 24px;" />
            <Label text="User ID" style="-fx-font-size: 11px; -fx-text-fill: #888;" />
            <Label fx:id="userIdLabel" text="-" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
        </VBox>
    </HBox>
</VBox>
