<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="750.0" prefWidth="1100.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterEvaluationController">
    <stylesheets>
        <URL value="@../modern.css" />
    </stylesheets>

    <BorderPane styleClass="client-dashboard-shell">
        <padding>
            <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
        </padding>

        <top>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="module-toolbar client-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title client-page-title" text="Assessment Studio" />
                    <Label styleClass="module-subtitle" text="Design and deploy new evaluations, exams, or projects for student assessment." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleCancel" styleClass="secondary-btn" text="← Return to Ledger" />
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-border-color: transparent;">
                <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 40 20 40 20;">
                    <VBox maxWidth="750.0" spacing="25.0" styleClass="module-card">
                        <Label styleClass="section-title" text="Evaluation Blueprint" />

                        <VBox spacing="20.0">
                            <VBox spacing="8" styleClass="module-card">
                                <Label styleClass="label-bold" text="Assessment Identity" />
                                <TextField fx:id="titleField" promptText="e.g. Advanced Data Structures Midterm" />
                            </VBox>

                            <VBox spacing="8" styleClass="module-card">
                                <Label styleClass="label-bold" text="Instructional Overview" />
                                <TextArea fx:id="descriptionArea" prefHeight="120" promptText="Outline the topics covered and student expectations..." wrapText="true" />
                            </VBox>

                            <HBox spacing="20">
                                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="module-card">
                                    <Label styleClass="label-bold" text="Assessment Type" />
                                    <ComboBox fx:id="typeComboBox" maxWidth="Infinity" promptText="Select delivery format" />
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="module-card">
                                    <Label styleClass="label-bold" text="Milestone Date" />
                                    <DatePicker fx:id="datePicker" maxWidth="Infinity" promptText="Choose assessment date" />
                                </VBox>
                            </HBox>

                            <HBox spacing="20">
                                 <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="module-card">
                                     <Label styleClass="label-bold" text="Grading Weight (0-100)" />
                                     <TextField fx:id="weightField" promptText="e.g. 25.0" />
                                 </VBox>
                                 <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="module-card">
                                     <Label styleClass="label-bold" text="Linked Competence" />
                                     <ComboBox fx:id="competenceComboBox" maxWidth="Infinity" promptText="Associate with a target skill" />
                                 </VBox>
                             </HBox>

                            <HBox spacing="20">
                                 <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="module-card">
                                     <Label styleClass="label-bold" text="Programming Language" />
                                     <ComboBox fx:id="languageComboBox" maxWidth="Infinity" promptText="Select language for coding exercises" />
                                 </VBox>
                             </HBox>

                            <VBox spacing="8" styleClass="module-card">
                                 <Label styleClass="label-bold" text="Code Template / Exercise Content" />
                                 <TextArea fx:id="codeContentArea" prefHeight="200" promptText="Enter code template, problem description or exercise content..." wrapText="false" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px;" />
                             </VBox>
                         </VBox>

                         <Separator />

                        <HBox alignment="CENTER" spacing="25">
                            <Button onAction="#handleCancel" prefWidth="180.0" styleClass="secondary-btn" text="Discard" />
                            <Button onAction="#handleCreate" prefWidth="250.0" styleClass="primary-btn" text="🚀 Deploy Assessment" />
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>
</StackPane>
