<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.ForgotPasswordController"
           style="-fx-background-color: #0b0f1a;">

    <!-- Background accent bar (left side) -->
    <Rectangle width="6" height="99999"
               fill="#4f6ef7"
               StackPane.alignment="CENTER_LEFT"
               translateX="0"/>

    <!-- Decorative top-right accent circle -->
    <Circle radius="180" fill="#1a2240"
            StackPane.alignment="TOP_RIGHT"
            translateX="90" translateY="-90"/>

    <!-- Decorative bottom-left subtle circle -->
    <Circle radius="120" fill="#111827"
            StackPane.alignment="BOTTOM_LEFT"
            translateX="-40" translateY="40"/>

    <!-- Main centered card -->
    <VBox alignment="CENTER" maxWidth="460" minWidth="420"
          style="-fx-background-color: #131929;
                 -fx-background-radius: 4;
                 -fx-border-color: #1e2d4a;
                 -fx-border-width: 1;
                 -fx-border-radius: 4;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 40, 0, 0, 12);"
          spacing="0"
          StackPane.alignment="CENTER">

        <!-- Top accent strip -->
        <HBox minHeight="4" style="-fx-background-color: linear-gradient(to right, #4f6ef7, #7c3aed); -fx-background-radius: 4 4 0 0;"/>

        <!-- Content area -->
        <VBox spacing="28" style="-fx-padding: 44 40 40 40;">

            <!-- HEADER -->
            <VBox spacing="10" alignment="CENTER_LEFT">
                <Label text="ACCOUNT RECOVERY"
                       style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #4f6ef7; -fx-letter-spacing: 3;"/>
                <Label text="Reset your&#10;password."
                       style="-fx-font-family: Georgia; -fx-font-size: 32px; -fx-font-weight: bold;
                              -fx-text-fill: #f0f4ff; -fx-line-spacing: 2;"/>
                <Label text="We'll guide you back in, step by step."
                       style="-fx-font-size: 13px; -fx-text-fill: #5a7099;"/>
            </VBox>

            <!-- Thin divider -->
            <Region minHeight="1" maxHeight="1"
                    style="-fx-background-color: #1e2d4a;"/>

            <!-- STEP 1: EMAIL -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="01"
                           style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #4f6ef7;"/>
                    <Label text="Enter your email address"
                           style="-fx-font-size: 12px; -fx-text-fill: #8aaace; -fx-font-weight: 600;
                                  -fx-letter-spacing: 0.5;"/>
                </HBox>
                <TextField fx:id="emailField" promptText="your@email.com"
                           style="-fx-background-color: #0d1525;
                                  -fx-border-color: #1e2d4a;
                                  -fx-border-width: 1;
                                  -fx-border-radius: 3;
                                  -fx-background-radius: 3;
                                  -fx-text-fill: #e8eeff;
                                  -fx-prompt-text-fill: #2e3f5c;
                                  -fx-font-size: 13px;
                                  -fx-padding: 13 16;"/>
                <Label fx:id="emailErrorLabel" text=""
                       style="-fx-text-fill: #f87171; -fx-font-size: 11px; -fx-font-family: 'Courier New';"/>
                <Button onAction="#sendCode" text="Send Reset Code  →"
                        prefHeight="44" maxWidth="Infinity"
                        style="-fx-background-color: #4f6ef7;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 3;
                               -fx-cursor: hand;
                               -fx-letter-spacing: 0.5;"/>
            </VBox>

            <!-- STEP 2: VERIFICATION CODE (hidden initially) -->
            <VBox fx:id="codeSection" spacing="10" visible="false" managed="false">
                <Region minHeight="1" maxHeight="1"
                        style="-fx-background-color: #1e2d4a;"/>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="02"
                           style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #7c3aed;"/>
                    <Label text="Enter verification code"
                           style="-fx-font-size: 12px; -fx-text-fill: #8aaace; -fx-font-weight: 600;
                                  -fx-letter-spacing: 0.5;"/>
                </HBox>
                <TextField fx:id="codeField" promptText="6-digit code"
                           style="-fx-background-color: #0d1525;
                                  -fx-border-color: #2a1f4a;
                                  -fx-border-width: 1;
                                  -fx-border-radius: 3;
                                  -fx-background-radius: 3;
                                  -fx-text-fill: #e8eeff;
                                  -fx-prompt-text-fill: #2e3f5c;
                                  -fx-font-size: 20px;
                                  -fx-font-family: 'Courier New';
                                  -fx-padding: 13 16;
                                  -fx-letter-spacing: 6;"/>
                <Label fx:id="codeErrorLabel" text=""
                       style="-fx-text-fill: #f87171; -fx-font-size: 11px; -fx-font-family: 'Courier New';"/>
                <Button onAction="#verifyCode" text="Verify Code  →"
                        prefHeight="44" maxWidth="Infinity"
                        style="-fx-background-color: #7c3aed;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 3;
                               -fx-cursor: hand;"/>
            </VBox>

            <!-- STEP 3: NEW PASSWORD (hidden initially) -->
            <VBox fx:id="passwordSection" spacing="10" visible="false" managed="false">
                <Region minHeight="1" maxHeight="1"
                        style="-fx-background-color: #1e2d4a;"/>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="03"
                           style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #10b981;"/>
                    <Label text="Set your new password"
                           style="-fx-font-size: 12px; -fx-text-fill: #8aaace; -fx-font-weight: 600;
                                  -fx-letter-spacing: 0.5;"/>
                </HBox>

                <Label text="NEW PASSWORD"
                       style="-fx-font-family: 'Courier New'; -fx-font-size: 9px; -fx-font-weight: bold;
                              -fx-text-fill: #3a5070; -fx-letter-spacing: 2;"/>
                <PasswordField fx:id="newPasswordField" promptText="Min. 4 characters"
                               style="-fx-background-color: #0d1525;
                                      -fx-border-color: #1e2d4a;
                                      -fx-border-width: 1;
                                      -fx-border-radius: 3;
                                      -fx-background-radius: 3;
                                      -fx-text-fill: #e8eeff;
                                      -fx-prompt-text-fill: #2e3f5c;
                                      -fx-font-size: 13px;
                                      -fx-padding: 13 16;"/>
                <Label fx:id="passwordErrorLabel" text=""
                       style="-fx-text-fill: #f87171; -fx-font-size: 11px; -fx-font-family: 'Courier New';"/>

                <Label text="CONFIRM PASSWORD"
                       style="-fx-font-family: 'Courier New'; -fx-font-size: 9px; -fx-font-weight: bold;
                              -fx-text-fill: #3a5070; -fx-letter-spacing: 2;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Repeat password"
                               style="-fx-background-color: #0d1525;
                                      -fx-border-color: #1e2d4a;
                                      -fx-border-width: 1;
                                      -fx-border-radius: 3;
                                      -fx-background-radius: 3;
                                      -fx-text-fill: #e8eeff;
                                      -fx-prompt-text-fill: #2e3f5c;
                                      -fx-font-size: 13px;
                                      -fx-padding: 13 16;"/>
                <Label fx:id="confirmErrorLabel" text=""
                       style="-fx-text-fill: #f87171; -fx-font-size: 11px; -fx-font-family: 'Courier New';"/>

                <Button onAction="#resetPassword" text="Reset Password  →"
                        prefHeight="44" maxWidth="Infinity"
                        style="-fx-background-color: #10b981;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 3;
                               -fx-cursor: hand;"/>
            </VBox>

            <!-- BACK BUTTON -->
            <HBox alignment="CENTER">
                <Button onAction="#goBackToLogin" text="← Back to Login"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #3a5070;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;
                               -fx-border-color: transparent;
                               -fx-underline: true;"/>
            </HBox>

        </VBox>
    </VBox>

</StackPane>
