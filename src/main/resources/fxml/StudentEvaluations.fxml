<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox fx:id="mainContainer" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.StudentEvaluationsController"
      spacing="0" stylesheets="@../modern.css">

    <!-- Evaluation Grid -->
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-bar">
            <padding>
                <Insets left="15" right="15" top="10" bottom="10"/>
            </padding>
            <TextField fx:id="searchField" promptText="Search evaluations..." styleClass="search-field"/>
            <ComboBox fx:id="statusFilter" promptText="Filter by status" styleClass="filter-combo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#refreshTable" styleClass="refresh-btn"/>
        </HBox>
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <FlowPane fx:id="evaluationGrid" hgap="15" vgap="15" prefWrapLength="1000" styleClass="evaluation-grid"/>
        </ScrollPane>
    </VBox>

    <!-- Header Bar -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="editor-header" visible="false" managed="false">
        <padding>
            <Insets left="15" right="15" top="10" bottom="10"/>
        </padding>
        <Button text="← Back" onAction="#closeEditor" styleClass="back-btn"/>
        <Label fx:id="exerciseTitle" styleClass="exercise-title" text="Exercise Title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="languageCombo" styleClass="language-combo"/>
        <ComboBox fx:id="themeCombo" styleClass="theme-combo"/>
    </HBox>

    <!-- Main SplitPane (Left: Instructions | Right: Editor) -->
    <SplitPane dividerPositions="0.35" VBox.vgrow="ALWAYS" visible="false" managed="false">

        <!-- LEFT PANEL: Instructions & Expected Output -->
        <VBox spacing="15" styleClass="left-panel">
            <padding>
                <Insets left="15" right="15" top="15" bottom="15"/>
            </padding>
            
            <!-- Exercise Description -->
            <VBox spacing="8">
                <Label text="📝 Exercise Description" styleClass="section-title"/>
                <TextArea fx:id="descriptionArea" wrapText="true" editable="false"
                          styleClass="description-area" VBox.vgrow="ALWAYS"/>
            </VBox>
            
            <!-- Expected Output -->
            <VBox spacing="8">
                <Label text="📌 Expected Output" styleClass="section-title"/>
                <TextArea fx:id="expectedOutputArea" prefHeight="120" wrapText="true"
                          editable="false" styleClass="expected-output-area"/>
            </VBox>
            
            <!-- Hints / Notes (optional) -->
            <VBox spacing="8">
                <Label text="💡 Hints" styleClass="section-title"/>
                <TextArea fx:id="hintsArea" prefHeight="80" wrapText="true"
                          editable="false" styleClass="hints-area"/>
            </VBox>
        </VBox>
        
        <!-- RIGHT PANEL: Code Editor -->
        <VBox spacing="10" styleClass="right-panel">
            <padding>
                <Insets left="10" right="10" top="10" bottom="10"/>
            </padding>
            
            <!-- Editor Labels -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="✏️ Write your solution:" styleClass="editor-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="charCountLabel" styleClass="char-count" text="0 chars"/>
            </HBox>
            
            <!-- MonacoFX Container -->
            <VBox fx:id="editorContainer" VBox.vgrow="ALWAYS" styleClass="editor-container"/>
        </VBox>
        
    </SplitPane>

    <!-- Action Buttons Bar -->
    <HBox alignment="CENTER" spacing="20" styleClass="action-bar" visible="false" managed="false">
        <padding>
            <Insets top="10" bottom="10"/>
        </padding>
        <Button fx:id="runButton" text="▶ Run Code" styleClass="run-button" onAction="#runCode"/>
        <Button fx:id="submitButton" text="✅ Submit" styleClass="submit-button" onAction="#submitSolution"/>
        <Button fx:id="clearConsoleButton" text="🗑 Clear Console" styleClass="clear-button" onAction="#clearConsole"/>
    </HBox>

    <!-- Bottom Output Console -->
    <VBox styleClass="console-panel" visible="false" managed="false">
        <Label text="📟 Output Console" styleClass="console-title"/>
        <TextArea fx:id="outputArea" editable="false" wrapText="true"
                  styleClass="console-area" VBox.vgrow="ALWAYS"/>
    </VBox>

</VBox>
