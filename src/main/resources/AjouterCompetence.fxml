<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?><?import javafx.scene.layout.*?><?import java.net.URL?>

<VBox fx:id="mainContainer" spacing="20" styleClass="light-theme" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterCompetenceController" prefWidth="600" prefHeight="500" >
    <padding>
        <Insets bottom="30" left="30" right="30" top="30"/>
    </padding>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label styleClass="title-label" text="➕ Add New Competence" HBox.hgrow="ALWAYS" />
        <Button onAction="#toggleTheme" text="🌙 Dark Mode" styleClass="theme-toggle-btn" />
    </HBox>

    <VBox spacing="15" styleClass="input-card" VBox.vgrow="ALWAYS">
        <Label styleClass="subtitle-label" text="Competence Information" />

        <VBox spacing="5">
            <Label text="Name" styleClass="label-bold" />
            <TextField fx:id="nameField" promptText="Enter competence name" />
        </VBox>

        <VBox spacing="5">
            <Label text="Description" styleClass="label-bold" />
            <TextArea fx:id="descriptionArea" promptText="Enter description" prefHeight="100" />
        </VBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Category" styleClass="label-bold" />
                <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Max Level (1-10)" styleClass="label-bold" />
                <Slider fx:id="levelSlider" min="1" max="10" value="5" showTickLabels="true" showTickMarks="true" />
            </VBox>
        </HBox>

        <VBox spacing="5">
            <Label text="Certificate (PDF)" styleClass="label-bold" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Upload PDF" onAction="#handleUpload" styleClass="btn-info" />
                <Label fx:id="fileNameLabel" text="No file selected" />
            </HBox>
        </VBox>
    </VBox>

    <HBox spacing="20" alignment="CENTER">
        <Button onAction="#handleAdd" text="✅ Add Competence" styleClass="btn-primary" />
        <Button onAction="#handleCancel" text="✖ Cancel" styleClass="btn-secondary" />
    </HBox>
</VBox>