<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane fx:id="mainContainer" prefHeight="650.0" prefWidth="800.0" styleClass="course-module-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterCompetenceController">
    <stylesheets>
        <URL value="@modern.css" />
    </stylesheets>
    
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="module-toolbar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>
                <VBox spacing="4.0">
                    <Label styleClass="module-title" text="Add New Competence" />
                    <Label styleClass="module-subtitle" text="Register a new skill or certification in your profile." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#toggleTheme" styleClass="secondary-btn" text="🌓 Theme" />
            </HBox>
        </top>

        <center>
            <VBox alignment="CENTER" style="-fx-padding: 30 0 0 0;">
                <VBox maxWidth="600.0" spacing="20.0" styleClass="module-card">
                    <Label styleClass="section-title" text="📋 Competence Details" />
                    
                    <VBox spacing="15.0">
                        <VBox spacing="5">
                            <Label styleClass="label-bold" text="Name" />
                            <TextField fx:id="nameField" promptText="e.g. Java Advanced, Project Management" />
                        </VBox>
                        
                        <VBox spacing="5">
                            <Label styleClass="label-bold" text="Description" />
                            <TextArea fx:id="descriptionArea" prefHeight="100" promptText="Provide a brief overview of this skill..." wrapText="true" />
                        </VBox>

                        <HBox spacing="15">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label styleClass="label-bold" text="Category" />
                                <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" promptText="Select category" />
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label styleClass="label-bold" text="Max Level (1-10)" />
                                <Slider fx:id="levelSlider" max="10" min="1" showTickLabels="true" value="5" />
                            </VBox>
                        </HBox>

                        <VBox spacing="5">
                            <Label styleClass="label-bold" text="Certificate (PDF)" />
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Button onAction="#handleUpload" styleClass="info-btn" text="📂 Upload Certificate" />
                                <Label fx:id="fileNameLabel" styleClass="meta-label" text="No file selected" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <Separator />

                    <HBox alignment="CENTER" spacing="20">
                        <Button onAction="#handleCancel" prefWidth="150.0" styleClass="secondary-btn" text="✖ Cancel" />
                        <Button onAction="#handleAdd" prefWidth="150.0" styleClass="primary-btn" text="✅ Add Skill" />
                    </HBox>
                </VBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
