<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?><?import javafx.scene.layout.*?><?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AjouterCompetenceController" prefWidth="600" prefHeight="400" styleClass="main-container" stylesheets="@style.css" >
    <children>
        <Label text="Add New Competence" style="-fx-font-size: 24; -fx-font-weight: bold;" />
        <GridPane hgap="10" vgap="15" alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints prefWidth="150" />
                <ColumnConstraints prefWidth="250" />
            </columnConstraints>
            <children>
                <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                
                <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextArea fx:id="descriptionArea" prefHeight="100" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                
                <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="categoryComboBox" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                
                <Label text="Max Level (1-10):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Slider fx:id="levelSlider" min="1" max="10" value="5" showTickLabels="true" showTickMarks="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>
        <HBox spacing="10" alignment="CENTER">
            <Button text="Add Competence" fx:id="addButton" onAction="#handleAdd" />
            <Button text="Cancel" fx:id="cancelButton" onAction="#handleCancel" />
        </HBox>
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>